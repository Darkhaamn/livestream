FROM golang:1.25-alpine AS build
WORKDIR /src
COPY services/chat/go.mod services/chat/go.sum ./
RUN go mod download
COPY services/chat/ ./
RUN CGO_ENABLED=0 go build -o /chat ./cmd/chat

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=build /chat /usr/local/bin/chat
EXPOSE 8082
CMD ["chat"]
